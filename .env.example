# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Email domain restriction (optional, leave empty to allow any email)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=yourdomain.com

# Allowed origins for development (comma-separated, optional)
ALLOWED_DEV_ORIGINS=localhost,your-domain.com
